<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".MainActivity">

    <!-- ===== App Bar ===== -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_card"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingHorizontal="8dp"
            app:title="@string/app_name"
            app:titleTextColor="@color/text_primary"
            app:titleTextAppearance="@style/TextAppearance.VoiceFlux.Title">

            <TextView
                android:id="@+id/tvLatency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_latency_chip"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/latency_default"
                android:textColor="@color/accent_cyan"
                android:textSize="11sp"
                tools:ignore="RtlHardcoded" />
        </com.google.android.material.appbar.MaterialToolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ===== Main scrollable content ===== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="220dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Waveform visualiser -->
            <com.voiceflux.app.ui.WaveformView
                android:id="@+id/waveformView"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp" />

            <!-- Preset grid -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:text="@string/voice_presets"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:letterSpacing="0.1" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPresets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ===== FAB — Toggle ===== -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="108dp"
        android:text="@string/start"
        android:textColor="@color/text_primary"
        app:backgroundTint="@color/accent_purple"
        app:iconTint="@color/text_primary"
        app:rippleColor="@color/accent_purple_ripple" />

    <!-- ===== Bottom Sheet — Effect Controls ===== -->
    <LinearLayout
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_sheet"
        android:orientation="vertical"
        android:paddingBottom="24dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="72dp"
        app:behavior_hideable="false">

        <!-- Handle + title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="12dp">

            <View
                android:layout_width="36dp"
                android:layout_height="4dp"
                android:background="@drawable/bg_handle"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/controls"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Preview chip: plays a 150 Hz buzz through the active preset -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPreview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="@string/preview"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/bg_card_elevated"
                    app:chipStrokeColor="@color/accent_purple"
                    app:chipStrokeWidth="1dp"
                    app:checkedIconVisible="false"
                    style="@style/Widget.MaterialComponents.Chip.Choice" />

                <ImageButton
                    android:id="@+id/btnExpandSheet"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/arrow_up_float"
                    android:tint="@color/text_secondary"
                    android:contentDescription="@string/expand_controls" />
            </LinearLayout>
        </LinearLayout>

        <!-- Sliders -->
        <include
            android:id="@+id/slidersLayout"
            layout="@layout/layout_sliders" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
